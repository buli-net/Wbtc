apply plugin: 'com.android.application'
android {
    namespace 'com.wbtc.wallet'
    compileSdk 36
    buildToolsVersion "36.0.0"
    compileOptions { sourceCompatibility 1_8; targetCompatibility 1_8 }
    defaultConfig {
        applicationId 'com.wbtc.wallet'
        minSdkVersion 21
        targetSdkVersion 36
        versionCode 1
        versionName "1.0"
    }
    dependencies {
        implementation 'androidx.activity:activity:1.9.2'
        implementation 'androidx.core:core:1.13.1'
        api fileTree(dir: '../libs', include: '*.aar')
        api fileTree(dir: '../libs', include: '*.jar')
    }
    packaging { jniLibs { useLegacyPackaging = true } }
}

// --- fix 2 lỗi của Gluon ---
afterEvaluate {
    // 1. Xóa package="" trong manifest
    tasks.configureEach { t ->
        if (t.name.toLowerCase().contains("manifest")) {
            t.doFirst {
                fileTree(dir: '.', include: '**/AndroidManifest.xml').each { mf ->
                    if (mf.text.contains('package=')) {
                        mf.text = mf.text.replaceAll(/package="[^"]*"/, '')
                        println ">>> Stripped package in $mf"
                    }
                }
            }
        }
    }
    // 2. Patch MainActivity enableEdgeToEdge -> API tương thích
    tasks.matching { it.name == "preBuild" || it.name == "preDebugBuild" }.configureEach {
        doFirst {
            def f = file('src/main/java/com/gluonhq/helloandroid/MainActivity.java')
            if (f.exists()) {
                def src = f.text
                if (src.contains('enableEdgeToEdge')) {
                    src = src.replace('WindowCompat.enableEdgeToEdge(getWindow());',
                                      'WindowCompat.setDecorFitsSystemWindows(getWindow(), false);')
                    f.text = src
                    println ">>> Patched MainActivity enableEdgeToEdge"
                }
            }
        }
    }
}
